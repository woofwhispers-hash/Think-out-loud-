<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Think Out Loud — AI Journal</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Mono:wght@300;400;500&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet"/>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ink:#1a1814;--ink2:#4a473f;--ink3:#9c9890;
  --paper:#faf8f4;--paper2:#f3f0e8;--paper3:#e8e3d8;
  --accent:#b5390a;--accent2:#d4521a;--accent-soft:#fff3ee;
  --pro:#5b21b6;--pro2:#7c3aed;--pro-soft:#f5f3ff;--pro-border:#ddd6fe;
  --border:rgba(26,24,20,0.1);--border2:rgba(26,24,20,0.2);
  --gold:#92610a;--green:#2d6a2d;
  --r:10px;--r2:14px;--r3:20px;
}
html,body{height:100%;background:var(--paper);}
body{font-family:'Lora',Georgia,serif;color:var(--ink);overflow-x:hidden;}

/* ── NOISE TEXTURE ── */
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:0.3;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:none;}}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
@keyframes shimmer{0%{background-position:-200% center;}100%{background-position:200% center;}}
@keyframes dot-bounce{0%,80%,100%{transform:scale(0.5);}40%{transform:scale(1);}}
@keyframes spin{to{transform:rotate(360deg);}}

/* ══════════════════════════════════════════
   LANDING PAGE
══════════════════════════════════════════ */
#page-landing{
  min-height:100svh;display:flex;flex-direction:column;
  background:var(--ink);color:var(--paper);
  position:relative;overflow:hidden;
}
.landing-bg{
  position:absolute;inset:0;
  background:radial-gradient(ellipse 80% 60% at 60% 20%,#3a2010 0%,transparent 60%),
             radial-gradient(ellipse 60% 80% at 20% 80%,#1a1030 0%,transparent 50%),
             var(--ink);
}
.landing-grid{
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(250,248,244,0.04) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(250,248,244,0.04) 1px,transparent 1px);
  background-size:60px 60px;
}
.landing-nav{
  position:relative;z-index:10;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.5rem 3rem;
}
.landing-logo{font-family:'Playfair Display',serif;font-size:1.2rem;font-style:italic;color:var(--paper);opacity:0.9;display:flex;align-items:center;gap:8px;}
.logo-mark{width:8px;height:8px;border-radius:50%;background:var(--accent2);}
.landing-nav-btns{display:flex;gap:10px;}
.nav-login-btn{padding:8px 20px;border-radius:var(--r3);font-family:'DM Mono',monospace;font-size:0.78rem;cursor:pointer;transition:all 0.2s;letter-spacing:0.03em;border:1px solid rgba(250,248,244,0.2);background:transparent;color:var(--paper);}
.nav-login-btn:hover{background:rgba(250,248,244,0.1);}
.nav-signup-btn{padding:8px 20px;border-radius:var(--r3);font-family:'DM Mono',monospace;font-size:0.78rem;cursor:pointer;transition:all 0.2s;letter-spacing:0.03em;border:none;background:var(--accent2);color:#fff;}
.nav-signup-btn:hover{background:var(--accent);}

.landing-hero{
  position:relative;z-index:10;flex:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:4rem 2rem;
}
.hero-eyebrow{font-family:'DM Mono',monospace;font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent2);margin-bottom:1.5rem;animation:fadeUp 0.8s ease both;}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(3rem,7vw,5.5rem);line-height:1.1;margin-bottom:1.5rem;animation:fadeUp 0.8s 0.1s ease both;}
.hero-title em{font-style:italic;color:var(--accent2);}
.hero-sub{max-width:520px;font-size:1.05rem;line-height:1.8;color:rgba(250,248,244,0.65);margin-bottom:2.5rem;animation:fadeUp 0.8s 0.2s ease both;}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;animation:fadeUp 0.8s 0.3s ease both;}
.hero-cta{padding:13px 32px;border-radius:var(--r3);font-family:'DM Mono',monospace;font-size:0.85rem;cursor:pointer;letter-spacing:0.04em;transition:all 0.2s;border:none;background:var(--accent2);color:#fff;font-weight:500;}
.hero-cta:hover{background:var(--accent);transform:translateY(-1px);}
.hero-cta-outline{padding:13px 32px;border-radius:var(--r3);font-family:'DM Mono',monospace;font-size:0.85rem;cursor:pointer;letter-spacing:0.04em;transition:all 0.2s;border:1px solid rgba(250,248,244,0.25);background:transparent;color:var(--paper);}
.hero-cta-outline:hover{background:rgba(250,248,244,0.08);}

.hero-features{display:flex;gap:2rem;flex-wrap:wrap;justify-content:center;margin-top:3rem;animation:fadeUp 0.8s 0.4s ease both;}
.hero-feat{display:flex;align-items:center;gap:8px;font-family:'DM Mono',monospace;font-size:0.72rem;color:rgba(250,248,244,0.5);letter-spacing:0.05em;}
.feat-dot{width:5px;height:5px;border-radius:50%;background:var(--accent2);}

.landing-footer{position:relative;z-index:10;text-align:center;padding:1.5rem;font-family:'DM Mono',monospace;font-size:0.68rem;color:rgba(250,248,244,0.3);}

/* ══════════════════════════════════════════
   AUTH PAGE (Login / Signup)
══════════════════════════════════════════ */
#page-auth{
  min-height:100svh;display:none;
  background:var(--paper);
  align-items:center;justify-content:center;
  padding:2rem;
}
.auth-card{
  width:100%;max-width:420px;
  background:var(--paper);border:1px solid var(--border2);
  border-radius:var(--r2);padding:2.5rem;
  box-shadow:0 4px 40px rgba(26,24,20,0.08);
  animation:fadeUp 0.4s ease both;
}
.auth-logo{font-family:'Playfair Display',serif;font-size:1.1rem;font-style:italic;color:var(--ink);margin-bottom:2rem;display:flex;align-items:center;gap:7px;}
.auth-logo .logo-mark{background:var(--accent2);}
.auth-title{font-size:1.4rem;font-weight:500;margin-bottom:0.4rem;}
.auth-sub{font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--ink3);margin-bottom:1.75rem;}
.form-group{margin-bottom:1rem;}
.form-label{font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--ink2);display:block;margin-bottom:6px;letter-spacing:0.03em;}
.form-input{
  width:100%;padding:10px 13px;font-size:0.95rem;font-family:'Lora',serif;
  color:var(--ink);background:var(--paper2);
  border:1px solid var(--border2);border-radius:var(--r);outline:none;
  transition:border-color 0.15s,box-shadow 0.15s;
}
.form-input:focus{border-color:var(--accent2);box-shadow:0 0 0 3px rgba(212,82,26,0.1);}
.form-input::placeholder{color:var(--ink3);}
.auth-btn{
  width:100%;padding:11px;background:var(--ink);color:var(--paper);
  border:none;border-radius:var(--r);font-family:'DM Mono',monospace;
  font-size:0.82rem;cursor:pointer;letter-spacing:0.04em;
  transition:all 0.15s;margin-top:0.5rem;
  display:flex;align-items:center;justify-content:center;gap:8px;
}
.auth-btn:hover{background:var(--ink2);}
.auth-btn:disabled{opacity:0.5;cursor:default;}
.auth-divider{text-align:center;font-family:'DM Mono',monospace;font-size:0.7rem;color:var(--ink3);margin:1.25rem 0;position:relative;}
.auth-divider::before{content:'';position:absolute;top:50%;left:0;right:0;height:1px;background:var(--border);}
.auth-divider span{background:var(--paper);padding:0 12px;position:relative;}
.auth-switch{text-align:center;font-family:'DM Mono',monospace;font-size:0.73rem;color:var(--ink3);margin-top:1.25rem;}
.auth-switch a{color:var(--accent);cursor:pointer;text-decoration:none;}
.auth-switch a:hover{text-decoration:underline;}
.auth-error{background:#fef2f2;border:1px solid #fca5a5;border-radius:var(--r);padding:10px 13px;font-family:'DM Mono',monospace;font-size:0.75rem;color:#b91c1c;margin-bottom:1rem;display:none;}
.auth-success{background:#f0fdf4;border:1px solid #86efac;border-radius:var(--r);padding:10px 13px;font-family:'DM Mono',monospace;font-size:0.75rem;color:#15803d;margin-bottom:1rem;display:none;}
.back-link{font-family:'DM Mono',monospace;font-size:0.7rem;color:var(--ink3);cursor:pointer;margin-bottom:1.5rem;display:inline-flex;align-items:center;gap:5px;}
.back-link:hover{color:var(--ink2);}

/* ══════════════════════════════════════════
   MAIN APP
══════════════════════════════════════════ */
#page-app{display:none;flex-direction:column;min-height:100svh;}

/* NAV */
.app-nav{
  display:flex;align-items:center;justify-content:space-between;
  padding:0.9rem 2rem;border-bottom:1px solid var(--border);
  background:var(--paper);position:sticky;top:0;z-index:100;
}
.app-logo{font-family:'Playfair Display',serif;font-size:1rem;font-style:italic;color:var(--ink);display:flex;align-items:center;gap:7px;}
.nav-tabs{display:flex;gap:2px;background:var(--paper3);border-radius:var(--r3);padding:3px;}
.nav-tab{padding:6px 16px;border-radius:20px;font-size:0.75rem;letter-spacing:0.04em;font-family:'DM Mono',monospace;border:none;cursor:pointer;background:none;color:var(--ink3);transition:all 0.18s;}
.nav-tab.active{background:var(--paper);color:var(--ink);box-shadow:0 1px 4px rgba(0,0,0,0.09);}
.nav-right{display:flex;align-items:center;gap:8px;}
.user-email{font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--ink3);max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.pro-badge{font-family:'DM Mono',monospace;font-size:0.65rem;background:var(--pro2);color:#fff;padding:3px 9px;border-radius:20px;}
.free-badge{font-family:'DM Mono',monospace;font-size:0.65rem;background:var(--paper3);color:var(--ink3);padding:3px 9px;border-radius:20px;}
.upgrade-btn{font-family:'DM Mono',monospace;font-size:0.7rem;background:var(--pro2);color:#fff;border:none;border-radius:20px;padding:5px 12px;cursor:pointer;transition:opacity 0.15s;}
.upgrade-btn:hover{opacity:0.85;}
.signout-btn{font-family:'DM Mono',monospace;font-size:0.7rem;background:none;border:1px solid var(--border2);color:var(--ink3);border-radius:20px;padding:5px 12px;cursor:pointer;transition:all 0.15s;}
.signout-btn:hover{background:var(--paper2);}

/* PAGES */
.app-page{display:none;flex:1;animation:fadeIn 0.25s ease;}
.app-page.active{display:flex;flex-direction:column;}

/* WRITE */
.write-wrap{max-width:660px;width:100%;margin:0 auto;padding:3rem 2rem 7rem;display:flex;flex-direction:column;gap:1.5rem;flex:1;}
.write-date{font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--ink3);letter-spacing:0.1em;text-transform:uppercase;}
.write-title{font-family:'Playfair Display',serif;font-size:2rem;line-height:1.25;border:none;background:transparent;color:var(--ink);width:100%;outline:none;resize:none;overflow:hidden;min-height:1.3em;}
.write-title::placeholder{color:var(--ink3);}
.write-divider{height:1px;background:var(--border);}
.write-body{font-family:'Lora',serif;font-size:1.05rem;line-height:1.9;color:var(--ink);background:transparent;border:none;outline:none;width:100%;resize:none;min-height:340px;caret-color:var(--accent);}
.write-body::placeholder{color:var(--ink3);font-style:italic;}
.write-footer{position:fixed;bottom:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem;background:rgba(250,248,244,0.92);backdrop-filter:blur(8px);border-top:1px solid var(--border);}
.write-meta{display:flex;align-items:center;gap:12px;}
.wc{font-family:'DM Mono',monospace;font-size:0.7rem;color:var(--ink3);}
.limit-pill{font-family:'DM Mono',monospace;font-size:0.68rem;padding:3px 10px;border-radius:20px;background:var(--paper3);color:var(--ink3);}
.limit-pill.warn{background:#fef3c7;color:#92400e;}
.limit-pill.full{background:#fee2e2;color:#991b1b;}
.save-btn{display:flex;align-items:center;gap:7px;background:var(--ink);color:var(--paper);border:none;border-radius:var(--r3);padding:9px 22px;font-family:'DM Mono',monospace;font-size:0.78rem;cursor:pointer;transition:all 0.15s;}
.save-btn:hover{background:var(--ink2);}
.save-btn.saved{background:var(--paper3);color:var(--ink2);}

/* ENTRIES */
.entries-wrap{max-width:700px;width:100%;margin:0 auto;padding:2.5rem 2rem 4rem;display:flex;flex-direction:column;flex:1;}
.section-header{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:2rem;}
.section-title{font-family:'Playfair Display',serif;font-size:1.4rem;}
.section-sub{font-family:'DM Mono',monospace;font-size:0.7rem;color:var(--ink3);}
.entry-card{padding:1.4rem 0;border-bottom:1px solid var(--border);cursor:pointer;display:grid;grid-template-columns:1fr auto;gap:1rem;align-items:start;transition:opacity 0.15s;}
.entry-card:hover{opacity:0.75;}
.entry-card:hover .ec-title{color:var(--accent);}
.ec-title{font-size:1.05rem;font-weight:500;margin-bottom:0.4rem;transition:color 0.15s;line-height:1.4;}
.ec-preview{font-size:0.88rem;color:var(--ink3);line-height:1.65;font-style:italic;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.ec-meta{font-family:'DM Mono',monospace;font-size:0.67rem;color:var(--ink3);text-align:right;white-space:nowrap;}
.ec-wc{display:inline-block;margin-top:5px;background:var(--paper3);border-radius:10px;padding:2px 8px;font-family:'DM Mono',monospace;font-size:0.63rem;color:var(--ink3);}
.empty-state{text-align:center;padding:5rem 2rem;color:var(--ink3);}
.empty-icon{font-size:2rem;margin-bottom:12px;opacity:0.25;}
.empty-text{font-style:italic;font-size:0.95rem;}

/* ENTRY MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(26,24,20,0.5);z-index:500;display:flex;align-items:center;justify-content:center;padding:1rem;animation:fadeIn 0.2s;}
.modal-card{background:var(--paper);border-radius:var(--r2);max-width:620px;width:100%;max-height:88svh;overflow-y:auto;padding:2rem;position:relative;box-shadow:0 12px 48px rgba(0,0,0,0.18);}
.modal-x{position:absolute;top:1rem;right:1rem;background:var(--paper3);border:none;border-radius:50%;width:30px;height:30px;cursor:pointer;color:var(--ink2);display:flex;align-items:center;justify-content:center;font-size:1rem;}
.modal-date{font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--ink3);margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.08em;}
.modal-title{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:1rem;line-height:1.3;}
.modal-body{font-size:0.97rem;line-height:1.9;color:var(--ink2);white-space:pre-wrap;}
.modal-footer{margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--border);display:flex;justify-content:flex-end;}
.delete-btn{background:none;border:1px solid #fca5a5;color:#b91c1c;border-radius:var(--r);padding:6px 14px;font-size:0.78rem;cursor:pointer;font-family:'DM Mono',monospace;}
.delete-btn:hover{background:#fef2f2;}

/* INSIGHTS */
.insights-wrap{max-width:700px;width:100%;margin:0 auto;padding:2.5rem 2rem 4rem;display:flex;flex-direction:column;gap:1.5rem;flex:1;}
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.stat-box{background:var(--paper2);border:1px solid var(--border);border-radius:var(--r2);padding:1.1rem 1.2rem;}
.stat-lbl{font-family:'DM Mono',monospace;font-size:0.62rem;color:var(--ink3);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;}
.stat-val{font-family:'Playfair Display',serif;font-size:1.6rem;color:var(--ink);}
.stat-unit{font-size:0.7rem;color:var(--ink3);font-family:'DM Mono',monospace;}
.activity-box{background:var(--paper2);border:1px solid var(--border);border-radius:var(--r2);padding:1.2rem 1.4rem;}
.activity-lbl{font-family:'DM Mono',monospace;font-size:0.62rem;color:var(--ink3);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:1rem;}
.bars{display:flex;gap:5px;align-items:flex-end;height:56px;}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end;}
.bar{width:100%;border-radius:3px 3px 0 0;min-height:3px;}
.bar-lbl{font-family:'DM Mono',monospace;font-size:0.58rem;color:var(--ink3);}
.pro-lock-banner{background:var(--pro-soft);border:1px solid var(--pro-border);border-radius:var(--r2);padding:1.1rem 1.4rem;display:flex;align-items:center;gap:14px;}
.plb-icon{font-size:1.3rem;}
.plb-text{flex:1;}
.plb-title{font-size:0.9rem;font-weight:500;color:var(--pro2);margin-bottom:2px;}
.plb-sub{font-family:'DM Mono',monospace;font-size:0.7rem;color:var(--ink3);}
.plb-btn{background:var(--pro2);color:#fff;border:none;border-radius:var(--r);padding:8px 15px;font-family:'DM Mono',monospace;font-size:0.72rem;cursor:pointer;white-space:nowrap;transition:opacity 0.15s;}
.plb-btn:hover{opacity:0.85;}
.reflect-box{background:var(--accent-soft);border:1px solid #fcd9c0;border-radius:var(--r2);padding:1.1rem 1.4rem;display:flex;align-items:center;gap:14px;}
.rb-icon{font-size:1.4rem;}
.rb-text{flex:1;}
.rb-title{font-size:0.95rem;font-weight:500;color:var(--accent);margin-bottom:2px;}
.rb-sub{font-family:'DM Mono',monospace;font-size:0.7rem;color:var(--gold);}
.reflect-btn{background:var(--accent);color:#fff;border:none;border-radius:var(--r);padding:8px 16px;font-family:'DM Mono',monospace;font-size:0.75rem;cursor:pointer;white-space:nowrap;transition:opacity 0.15s;}
.reflect-btn:hover{opacity:0.85;}
.reflect-btn:disabled{opacity:0.5;cursor:default;}
.insight-result{background:var(--paper);border:1px solid var(--border);border-radius:var(--r2);padding:1.5rem;animation:fadeIn 0.3s;}
.ir-header{display:flex;align-items:center;gap:8px;margin-bottom:1rem;font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--ink3);text-transform:uppercase;letter-spacing:0.09em;}
.ir-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);}
.ir-text{font-size:0.97rem;line-height:1.9;color:var(--ink);white-space:pre-wrap;}
.loading-dots{display:inline-flex;gap:4px;align-items:center;}
.loading-dots span{width:5px;height:5px;border-radius:50%;background:var(--ink3);animation:dot-bounce 1.2s infinite;display:inline-block;}
.loading-dots span:nth-child(2){animation-delay:0.2s;}
.loading-dots span:nth-child(3){animation-delay:0.4s;}

/* ── PAYWALL MODAL ── */
.paywall-overlay{position:fixed;inset:0;background:rgba(26,24,20,0.55);z-index:600;display:flex;align-items:center;justify-content:center;padding:1rem;animation:fadeIn 0.2s;}
.paywall-card{background:var(--paper);border-radius:var(--r2);max-width:440px;width:100%;overflow:hidden;box-shadow:0 16px 56px rgba(0,0,0,0.22);position:relative;}
.paywall-top{background:linear-gradient(135deg,var(--pro) 0%,var(--pro2) 100%);padding:2rem 2rem 1.5rem;text-align:center;}
.pw-glyph{font-size:2rem;margin-bottom:0.75rem;}
.pw-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-style:italic;color:#fff;margin-bottom:0.3rem;}
.pw-sub{font-family:'DM Mono',monospace;font-size:0.68rem;color:rgba(255,255,255,0.65);letter-spacing:0.06em;}
.paywall-body{padding:1.5rem 2rem 2rem;}
.pw-features{display:flex;flex-direction:column;gap:10px;margin-bottom:1.5rem;}
.pw-feat{display:flex;align-items:center;gap:10px;font-size:0.9rem;}
.pw-check{width:22px;height:22px;border-radius:50%;background:var(--pro-soft);border:1px solid var(--pro-border);display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:var(--pro2);flex-shrink:0;}
.pw-price-row{display:flex;align-items:baseline;gap:6px;margin-bottom:1.25rem;}
.pw-price{font-family:'Playfair Display',serif;font-size:2.2rem;color:var(--pro2);}
.pw-period{font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--ink3);}
.pw-note{font-family:'DM Mono',monospace;font-size:0.67rem;color:var(--ink3);margin-left:auto;}
.pw-pay-btn{width:100%;padding:13px;background:var(--pro2);color:#fff;border:none;border-radius:var(--r);font-family:'DM Mono',monospace;font-size:0.85rem;cursor:pointer;letter-spacing:0.04em;transition:opacity 0.15s;margin-bottom:10px;}
.pw-pay-btn:hover{opacity:0.87;}
.pw-pay-btn:disabled{opacity:0.5;cursor:default;}
.pw-dismiss{display:block;width:100%;text-align:center;font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--ink3);cursor:pointer;background:none;border:none;padding:4px;}
.pw-dismiss:hover{color:var(--ink2);}
.pw-x{position:absolute;top:0.7rem;right:0.7rem;background:rgba(255,255,255,0.18);border:none;border-radius:50%;width:28px;height:28px;cursor:pointer;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.9rem;}

/* TOAST */
.toast{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:var(--ink);color:var(--paper);border-radius:var(--r3);padding:10px 22px;font-family:'DM Mono',monospace;font-size:0.78rem;z-index:9000;animation:fadeUp 0.3s;white-space:nowrap;pointer-events:none;}

/* SPINNER */
.spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);border-top-color:#fff;border-radius:50%;animation:spin 0.7s linear infinite;}
</style>
</head>
<body>

<!-- ══════════════ LANDING ══════════════ -->
<div id="page-landing" style="display:flex;">
  <div class="landing-bg"></div>
  <div class="landing-grid"></div>
  <nav class="landing-nav">
    <div class="landing-logo"><span class="logo-mark"></span>Think Out Loud</div>
    <div class="landing-nav-btns">
      <button class="nav-login-btn" onclick="showAuth('login')">Sign in</button>
      <button class="nav-signup-btn" onclick="showAuth('signup')">Get started free</button>
    </div>
  </nav>
  <div class="landing-hero">
    <div class="hero-eyebrow">✦ AI-powered journaling</div>
    <h1 class="hero-title">Where your thoughts<br><em>find their patterns</em></h1>
    <p class="hero-sub">Write freely every day. Our AI quietly reads your entries and surfaces the patterns, emotions, and themes you didn't notice yourself.</p>
    <div class="hero-btns">
      <button class="hero-cta" onclick="showAuth('signup')">Start writing free →</button>
