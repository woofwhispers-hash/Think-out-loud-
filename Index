      <div class="hero-feat"><span class="feat-dot"></span>No ads ever</div>
    </div>
  </div>
  <div class="landing-footer">© 2025 Think Out Loud · Made with care</div>
</div>

<!-- ══════════════ AUTH ══════════════ -->
<div id="page-auth" style="display:none;min-height:100svh;background:var(--paper2);align-items:center;justify-content:center;padding:2rem;">
  <div class="auth-card">
    <div class="auth-logo"><span class="logo-mark"></span>Think Out Loud</div>
    <div class="auth-error" id="auth-error"></div>
    <div class="auth-success" id="auth-success"></div>

    <!-- LOGIN FORM -->
    <div id="form-login">
      <div class="auth-title">Welcome back</div>
      <div class="auth-sub">Sign in to continue writing</div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input class="form-input" type="email" id="login-email" placeholder="you@example.com" autocomplete="email"/>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input class="form-input" type="password" id="login-password" placeholder="••••••••" autocomplete="current-password"/>
      </div>
      <button class="auth-btn" id="login-btn" onclick="handleLogin()">
        <span>Sign in</span>
      </button>
      <div class="auth-switch">No account? <a onclick="switchAuth('signup')">Create one free →</a></div>
      <div class="auth-switch" style="margin-top:6px;"><a onclick="showAuth('landing')" style="color:var(--ink3);">← Back to home</a></div>
    </div>

    <!-- SIGNUP FORM -->
    <div id="form-signup" style="display:none;">
      <div class="auth-title">Start your journal</div>
      <div class="auth-sub">Free · No credit card required</div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input class="form-input" type="email" id="signup-email" placeholder="you@example.com" autocomplete="email"/>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input class="form-input" type="password" id="signup-password" placeholder="Min. 6 characters" autocomplete="new-password"/>
      </div>
      <button class="auth-btn" id="signup-btn" onclick="handleSignup()">
        <span>Create account</span>
      </button>
      <div class="auth-switch">Already have an account? <a onclick="switchAuth('login')">Sign in →</a></div>
      <div class="auth-switch" style="margin-top:6px;"><a onclick="showAuth('landing')" style="color:var(--ink3);">← Back to home</a></div>
    </div>
  </div>
</div>

<!-- ══════════════ MAIN APP ══════════════ -->
<div id="page-app" style="display:none;flex-direction:column;min-height:100svh;">
  <nav class="app-nav">
    <div class="app-logo"><span class="logo-mark"></span>Think Out Loud</div>
    <div class="nav-tabs">
      <button class="nav-tab active" onclick="switchTab('write',this)">Write</button>
      <button class="nav-tab" onclick="switchTab('entries',this)">Entries</button>
      <button class="nav-tab" onclick="switchTab('insights',this)">Insights</button>
    </div>
    <div class="nav-right" id="nav-right"></div>
  </nav>

  <!-- WRITE TAB -->
  <div class="app-page active" id="tab-write">
    <div class="write-wrap">
      <div class="write-date" id="write-date"></div>
      <textarea class="write-title" id="write-title" placeholder="What's on your mind today?" rows="1" oninput="autoResize(this);onType();"></textarea>
      <div class="write-divider"></div>
      <textarea class="write-body" id="write-body" placeholder="Just start writing… there's no right way to do this." oninput="onType();"></textarea>
    </div>
    <div class="write-footer">
      <div class="write-meta">
        <span class="wc" id="wc">0 words</span>
        <span class="limit-pill" id="limit-pill" style="display:none;"></span>
      </div>
      <button class="save-btn" id="save-btn" onclick="saveEntry()">✦ Save entry</button>
    </div>
  </div>

  <!-- ENTRIES TAB -->
  <div class="app-page" id="tab-entries">
    <div class="entries-wrap">
      <div class="section-header">
        <div class="section-title">Your journal</div>
        <div class="section-sub" id="entries-sub"></div>
      </div>
      <div id="entries-list"></div>
    </div>
  </div>

  <!-- INSIGHTS TAB -->
  <div class="app-page" id="tab-insights">
    <div class="insights-wrap">
      <div>
        <div class="section-title" style="font-family:'Playfair Display',serif;">Patterns & reflections</div>
        <div style="font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--ink3);margin-top:4px;">AI reads your entries and surfaces what you might not notice</div>
      </div>
      <div class="stats-grid" id="stats-grid"></div>
      <div class="activity-box" id="activity-box" style="display:none;">
        <div class="activity-lbl">Writing activity — last 7 days</div>
        <div class="bars" id="bars"></div>
      </div>
      <div id="pro-banner"></div>
      <div class="reflect-box">
        <div class="rb-icon">✦</div>
        <div class="rb-text">
          <div class="rb-title">Reflect with AI</div>
          <div class="rb-sub" id="reflect-sub">Analyse your recent entries for patterns</div>
        </div>
        <button class="reflect-btn" id="reflect-btn" onclick="handleReflect()">Reflect →</button>
      </div>
      <div id="insight-out"></div>
    </div>
  </div>
</div>

<!-- ENTRY DETAIL MODAL -->
<div class="modal-overlay" id="entry-modal" style="display:none;" onclick="if(event.target.id==='entry-modal')this.style.display='none'">
  <div class="modal-card">
    <button class="modal-x" onclick="document.getElementById('entry-modal').style.display='none'">✕</button>
    <div class="modal-date" id="m-date"></div>
    <div class="modal-title" id="m-title"></div>
    <div class="modal-body" id="m-body"></div>
    <div class="modal-footer"><button class="delete-btn" id="m-del">Delete entry</button></div>
  </div>
</div>

<!-- PAYWALL MODAL -->
<div class="paywall-overlay" id="paywall" style="display:none;" onclick="if(event.target.id==='paywall')closePW()">
  <div class="paywall-card">
    <button class="pw-x" onclick="closePW()">✕</button>
    <div class="paywall-top">
      <div class="pw-glyph">✦</div>
      <div class="pw-title">Unlock Think Out Loud Pro</div>
      <div class="pw-sub">YOUR FULL INNER WORLD, UNRESTRICTED</div>
    </div>
    <div class="paywall-body">
      <div class="pw-features">
        <div class="pw-feat"><div class="pw-check">∞</div>Unlimited entries (free = 5/month)</div>
        <div class="pw-feat"><div class="pw-check">✦</div>Unlimited AI reflections & pattern insights</div>
        <div class="pw-feat"><div class="pw-check">↓</div>Export your journal as PDF</div>
        <div class="pw-feat"><div class="pw-check">☁</div>Cloud sync & priority support</div>
      </div>
      <div class="pw-price-row">
        <span class="pw-price">₹299</span>
        <span class="pw-period">/ month</span>
        <span class="pw-note">Cancel anytime</span>
      </div>
      <button class="pw-pay-btn" id="pw-pay-btn" onclick="startPayment()">Pay with Razorpay →</button>
      <button class="pw-dismiss" onclick="closePW()">Maybe later</button>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════
// CONFIG
// ══════════════════════════════════════════
const SUPABASE_URL  = 'YOUR_SUPABASE_URL';
const SUPABASE_ANON = 'YOUR_SUPABASE_ANON_KEY';
const RZP_KEY       = 'rzp_test_SrUXHkbYv4YdmE';
const RZP_AMOUNT    = 29900; // ₹299
const FREE_LIMIT    = 5;

// ── Init Supabase ──
const { createClient } = supabase;
const sb = createClient(SUPABASE_URL, SUPABASE_ANON);

// ══════════════════════════════════════════
// STATE
// ══════════════════════════════════════════
let currentUser = null;
let entries     = [];
let isPro       = false;

// ══════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════
const DAYS   = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const SDAYS  = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const today  = ()=> new Date().toISOString().split('T')[0];
const wc     = s=> s.trim() ? s.trim().split(/\s+/).length : 0;
const totWds = ()=> entries.reduce((a,e)=>a+wc(e.title+' '+e.body),0);
const thisM  = ()=> { const m=today().slice(0,7); return entries.filter(e=>e.date.startsWith(m)); };
const esc    = s=> s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const fmtD   = iso=>{ const d=new Date(iso+'T00:00:00'); return `${DAYS[d.getDay()]}, ${d.getDate()} ${MONTHS[d.getMonth()]} ${d.getFullYear()}`; };
const fmtS   = iso=>{ const d=new Date(iso+'T00:00:00'); return `${d.getDate()} ${MONTHS[d.getMonth()].slice(0,3)}`; };

function toast(msg){
  const t=document.createElement('div'); t.className='toast'; t.textContent=msg;
  document.body.appendChild(t); setTimeout(()=>t.remove(),3000);
}
function autoResize(el){ el.style.height='auto'; el.style.height=el.scrollHeight+'px'; }
function setLoading(btn, loading, text){
  btn.disabled=loading;
  btn.innerHTML=loading ? '<span class="spinner"></span>' : `<span>${text}</span>`;
}

// ══════════════════════════════════════════
// PAGE ROUTING
// ══════════════════════════════════════════
function showLanding(){ document.getElementById('page-landing').style.display='flex'; document.getElementById('page-auth').style.display='none'; document.getElementById('page-app').style.display='none'; }
function showAuthPage(){ document.getElementById('page-landing').style.display='none'; document.getElementById('page-auth').style.display='flex'; document.getElementById('page-app').style.display='none'; }
function showApp(){ document.getElementById('page-landing').style.display='none'; document.getElementById('page-auth').style.display='none'; document.getElementById('page-app').style.display='flex'; }

function showAuth(target){
  if(target==='landing'){ showLanding(); return; }
  showAuthPage();
  if(target==='signup') switchAuth('signup'); else switchAuth('login');
}
function switchAuth(form){
  document.getElementById('form-login').style.display  = form==='login'  ? '' : 'none';
  document.getElementById('form-signup').style.display = form==='signup' ? '' : 'none';
  clearAuthMsg();
}
function clearAuthMsg(){
  ['auth-error','auth-success'].forEach(id=>{ const el=document.getElementById(id); el.style.display='none'; el.textContent=''; });
}
function showAuthError(msg){ const e=document.getElementById('auth-error'); e.textContent=msg; e.style.display=''; document.getElementById('auth-success').style.display='none'; }
function showAuthSuccess(msg){ const s=document.getElementById('auth-success'); s.textContent=msg; s.style.display=''; document.getElementById('auth-error').style.display='none'; }

// ══════════════════════════════════════════
// AUTH
// ══════════════════════════════════════════
async function handleLogin(){
  const email=document.getElementById('login-email').value.trim();
  const pass=document.getElementById('login-password').value;
  if(!email||!pass){ showAuthError('Please fill in all fields.'); return; }
  const btn=document.getElementById('login-btn');
  setLoading(btn,true,''); clearAuthMsg();
  const {data,error}=await sb.auth.signInWithPassword({email,password:pass});
  if(error){ showAuthError(error.message); setLoading(btn,false,'Sign in'); return; }
  await onLogin(data.user);
}

async function handleSignup(){
  const email=document.getElementById('signup-email').value.trim();
  const pass=document.getElementById('signup-password').value;
  if(!email||!pass){ showAuthError('Please fill in all fields.'); return; }
  if(pass.length<6){ showAuthError('Password must be at least 6 characters.'); return; }
  const btn=document.getElementById('signup-btn');
  setLoading(btn,true,''); clearAuthMsg();
  const {data,error}=await sb.auth.signUp({email,password:pass});
  if(error){ showAuthError(error.message); setLoading(btn,false,'Create account'); return; }
  if(data.user && !data.session){
    showAuthSuccess('Check your email to confirm your account, then sign in!');
    setLoading(btn,false,'Create account');
  } else if(data.user){
    await onLogin(data.user);
  }
}

async function onLogin(user){
  currentUser=user;
  await loadUserData();
  showApp();
  initApp();
}

async function handleSignout(){
  await sb.auth.signOut();
  currentUser=null; entries=[]; isPro=false;
  showLanding();
}

// ══════════════════════════════════════════
// DATA (Supabase)
// ══════════════════════════════════════════
async function loadUserData(){
  // Load entries
  const {data:ents}=await sb.from('entries').select('*').eq('user_id',currentUser.id).order('date',{ascending:false});
  entries=ents||[];
  // Load pro status
  const {data:profile}=await sb.from('profiles').select('is_pro').eq('id',currentUser.id).single();
  isPro=profile?.is_pro||false;
}

async function persistEntry(entry){
  if(entry.id && typeof entry.id === 'string' && entry.id.includes('-')){
    // update
    await sb.from('entries').update({title:entry.title,body:entry.body,updated_at:new Date().toISOString()}).eq('id',entry.id);
  } else {
    // insert
    const {data}=await sb.from('entries').insert({user_id:currentUser.id,date:entry.date,title:entry.title,body:entry.body}).select().single();
    if(data) entry.id=data.id;
  }
}

async function removeEntry(id){
  await sb.from('entries').delete().eq('id',id);
}

async function setProStatus(paymentId){
  await sb.from('profiles').upsert({id:currentUser.id,is_pro:true,payment_id:paymentId,updated_at:new Date().toISOString()});
  isPro=true;
}

// ══════════════════════════════════════════
// APP INIT
// ══════════════════════════════════════════
function initApp(){
  document.getElementById('write-date').textContent = fmtD(today()).toUpperCase();
  updateWC(); renderNavRight(); updateLimitPill();
}

function renderNavRight(){
  const el=document.getElementById('nav-right');
  const email=currentUser?.email||'';
  el.innerHTML=`
    <span class="user-email">${esc(email)}</span>
    ${isPro
      ? `<span class="pro-badge">✦ PRO</span>`
      : `<span class="free-badge">${Math.max(0,FREE_LIMIT-thisM().length)} left</span>
         <button class="upgrade-btn" onclick="openPW()">Upgrade ↑</button>`}
    <button class="signout-btn" onclick="handleSignout()">Sign out</button>`;
}

function updateWC(){
  const n=wc(document.getElementById('write-title').value+' '+document.getElementById('write-body').value);
  document.getElementById('wc').textContent=n+(n===1?' word':' words');
}

function updateLimitPill(){
  const pill=document.getElementById('limit-pill');
  if(isPro){ pill.style.display='none'; return; }
  const used=thisM().length, left=FREE_LIMIT-used;
  pill.style.display='';
  pill.textContent=`${used}/${FREE_LIMIT} entries this month`;
  pill.className='limit-pill'+(left<=1?' warn':'')+(left<=0?' full':'');
}

function onType(){
  updateWC();
  const btn=document.getElementById('save-btn');
  btn.textContent='✦ Save entry'; btn.className='save-btn';
}

// ══════════════════════════════════════════
// TABS
// ══════════════════════════════════════════
function switchTab(name,btn){
  document.querySelectorAll('.app-page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
  if(name==='entries') renderEntries();
  if(name==='insights') renderInsights();
}

// ══════════════════════════════════════════
// SAVE
// ══════════════════════════════════════════
async function saveEntry(){
  const title=document.getElementById('write-title').value.trim();
  const body=document.getElementById('write-body').value.trim();
  if(!title&&!body) return;
  const t=today();
  const existing=entries.findIndex(e=>e.date===t);
  if(!isPro && existing<0 && thisM().length>=FREE_LIMIT){ openPW(); return; }
  const btn=document.getElementById('save-btn');
  btn.innerHTML='<span class="spinner" style="border-color:rgba(250,248,244,0.3);border-top-color:#faf8f4;"></span>';
  btn.disabled=true;
  const entry=existing>=0 ? {...entries[existing],title:title||'Untitled',body} : {date:t,title:title||'Untitled',body};
  await persistEntry(entry);
  if(existing>=0) entries[existing]=entry; else entries.unshift(entry);
  btn.textContent='✓ Saved'; btn.className='save-btn saved'; btn.disabled=false;
  setTimeout(()=>{ btn.textContent='✦ Save entry'; btn.className='save-btn'; },2200);
  updateLimitPill(); renderNavRight();
}

// ══════════════════════════════════════════
// ENTRIES
// ══════════════════════════════════════════
function renderEntries(){
  const list=document.getElementById('entries-list'), sub=document.getElementById('entries-sub');
  if(!entries.length){
    sub.textContent=''; list.innerHTML='<div class="empty-state"><div class="empty-icon">✦</div><div class="empty-text">Your journal is empty.<br>Start writing on the Write tab.</div></div>';
    return;
  }
  sub.textContent=entries.length+' entr'+(entries.length===1?'y':'ies')+' · '+totWds().toLocaleString('en-IN')+' words';
  list.innerHTML=entries.map(e=>`
    <div class="entry-card" onclick="openModal('${e.id}')">
      <div>
        <div class="ec-title">${esc(e.title)}</div>
        <div class="ec-preview">${esc(e.body.slice(0,140))}${e.body.length>140?'…':''}</div>
        <span class="ec-wc">${wc(e.title+' '+e.body)} words</span>
      </div>
      <div class="ec-meta">${fmtS(e.date)}</div>
    </div>`).join('');
}

function openModal(id){
  const e=entries.find(x=>x.id==id); if(!e) return;
  document.getElementById('m-date').textContent=fmtD(e.date).toUpperCase();
  document.getElementById('m-title').textContent=e.title;
  document.getElementById('m-body').textContent=e.body;
  document.getElementById('m-del').onclick=()=>deleteEntry(e.id);
  document.getElementById('entry-modal').style.display='flex';
}

async function deleteEntry(id){
  if(!confirm('Delete this entry?')) return;
  await removeEntry(id);
  entries=entries.filter(e=>e.id!=id);
  document.getElementById('entry-modal').style.display='none';
  renderEntries(); renderNavRight(); updateLimitPill();
}

// ══════════════════════════════════════════
// INSIGHTS
// ══════════════════════════════════════════
function calcStreak(){
  if(!entries.length) return 0;
  const dates=new Set(entries.map(e=>e.date)); let s=0,d=new Date();
  while(true){ const iso=d.toISOString().split('T')[0]; if(dates.has(iso)){s++;d.setDate(d.getDate()-1);}else break; }
  return s;
}

function renderInsights(){
  const n=entries.length,tw=totWds(),streak=calcStreak();
  document.getElementById('stats-grid').innerHTML=`
    <div class="stat-box"><div class="stat-lbl">Entries</div><div class="stat-val">${n}<span class="stat-unit"> total</span></div></div>
    <div class="stat-box"><div class="stat-lbl">Words</div><div class="stat-val">${tw.toLocaleString('en-IN')}<span class="stat-unit"> written</span></div></div>
    <div class="stat-box"><div class="stat-lbl">Streak</div><div class="stat-val">${streak}<span class="stat-unit"> day${streak!==1?'s':''}</span></div></div>`;

  const ab=document.getElementById('activity-box');
  if(n>0){
    ab.style.display='';
    const days=[];
    for(let i=6;i>=0;i--){ const d=new Date(); d.setDate(d.getDate()-i); const iso=d.toISOString().split('T')[0]; const e=entries.find(x=>x.date===iso); days.push({l:SDAYS[d.getDay()],w:e?wc(e.title+' '+e.body):0}); }
    const mx=Math.max(...days.map(d=>d.w),1);
    document.getElementById('bars').innerHTML=days.map(d=>{ const h=Math.max(3,Math.round((d.w/mx)*48)); return `<div class="bar-col"><div class="bar" style="height:${h}px;background:${d.w>0?'var(--accent)':'var(--paper3)'}" title="${d.w} words"></div><span class="bar-lbl">${d.l}</span></div>`; }).join('');
  } else { ab.style.display='none'; }

  document.getElementById('pro-banner').innerHTML=!isPro
    ? `<div class="pro-lock-banner"><div class="plb-icon">🔒</div><div class="plb-text"><div class="plb-title">AI Insights is a Pro feature</div><div class="plb-sub">Upgrade to unlock unlimited reflections</div></div><button class="plb-btn" onclick="openPW()">Upgrade ↑</button></div>`
    : '';

  const rb=document.getElementById('reflect-btn'), rs=document.getElementById('reflect-sub');
  if(n<2){ rs.textContent='Write at least 2 entries to unlock'; rb.disabled=true; }
  else{ rs.textContent=`Analyse your ${Math.min(n,10)} most recent entries`; rb.disabled=false; }
}

function handleReflect(){ if(!isPro){ openPW(); } else { runInsights(); } }

async function runInsights(){
  const btn=document.getElementById('reflect-btn'), out=document.getElementById('insight-out');
  btn.disabled=true; btn.textContent='Thinking…';
  const corpus=entries.slice(0,10).map((e,i)=>`Entry ${i+1} (${fmtD(e.date)})\nTitle: ${e.title}\n${e.body}`).join('\n\n---\n\n');
  out.innerHTML=`<div class="insight-result"><div class="ir-header"><span class="ir-dot"></span>Reading your entries</div><div class="ir-text"><span class="loading-dots"><span></span><span></span><span></span></span></div></div>`;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:`You are a warm, perceptive journal companion. Surface 3–5 specific, meaningful patterns. Reference actual words/themes. Use "you". Start each insight with "✦ " on a new line, 2–3 sentences. End with one gentle open-ended question. Plain text only.`,messages:[{role:'user',content:`My journal entries:\n\n${corpus}\n\nWhat patterns or insights do you notice?`}]})});
    const data=await res.json();
    out.innerHTML=`<div class="insight-result"><div class="ir-header"><span class="ir-dot"></span>AI reflection · ${new Date().toLocaleDateString('en-IN',{day:'numeric',month:'short'})}</div><div class="ir-text">${esc(data.content?.[0]?.text||'Could not generate insights.')}</div></div>`;
  }catch(e){
    out.innerHTML=`<div class="insight-result"><div class="ir-header"><span class="ir-dot"></span>Error</div><div class="ir-text">Something went wrong. Check your connection and try again.</div></div>`;
  }
  btn.disabled=false; btn.textContent='Reflect again →';
}

// ══════════════════════════════════════════
// PAYWALL + RAZORPAY
// ══════════════════════════════════════════
function openPW(){ document.getElementById('paywall').style.display='flex'; }
function closePW(){ document.getElementById('paywall').style.display='none'; }

function startPayment(){
  const btn=document.getElementById('pw-pay-btn');
  btn.disabled=true; btn.textContent='Opening Razorpay…';
  const options={
    key:RZP_KEY,amount:RZP_AMOUNT,currency:'INR',
    name:'Think Out Loud',description:'Pro — 1 month unlimited',
    theme:{color:'#5b21b6'},
    handler:async function(response){
      await setProStatus(response.razorpay_payment_id);
      closePW(); renderNavRight(); updateLimitPill();
      toast('✦ Welcome to Pro! AI insights are now unlocked.');
      if(document.getElementById('tab-insights').classList.contains('active')) renderInsights();
    },
    modal:{ ondismiss:()=>{ btn.disabled=false; btn.textContent='Pay with Razorpay →'; } }
  };
  try{
    const rzp=new Razorpay(options);
    rzp.on('payment.failed',r=>{ alert('Payment failed: '+r.error.description); btn.disabled=false; btn.textContent='Pay with Razorpay →'; });
    rzp.open();
  }catch(e){
    alert('Could not open Razorpay. Check your Key ID.'); btn.disabled=false; btn.textContent='Pay with Razorpay →';
  }
}

// ══════════════════════════════════════════
// BOOT — check existing session
// ══════════════════════════════════════════
(async()=>{
  const {data:{session}}=await sb.auth.getSession();
  if(session?.user){
    currentUser=session.user;
    await loadUserData();
    showApp();
    initApp();
  } else {
    showLanding();
  }
  // listen for auth changes
  sb.auth.onAuthStateChange(async(event,session)=>{
    if(event==='SIGNED_IN'&&session?.user&&!currentUser){
      currentUser=session.user;
      await loadUserData();
      showApp();
      initApp();
    } else if(event==='SIGNED_OUT'){
      currentUser=null; entries=[]; isPro=false;
      showLanding();
    }
  });
})();
</script>
